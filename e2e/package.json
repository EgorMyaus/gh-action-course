{
  "name": "e2e",
  "version": "1.0.0",
  "description": "Cucumber-Playwright E2E Tests with ReportPortal Integration",
  "main": "index.js",
  "scripts": {
    "precucumber": "rimraf reports && mkdir reports && echo {} > reports/report.json",
    "transpile": "rimraf dist && babel --extensions .ts --out-dir dist src",
    "cucumber": "yarn transpile && cucumber-js",
    "cucumber:localhost": "NODE_ENV=localhost COMMON_CONFIG_FILE=env/common.env yarn cucumber",
    "cucumber:docker": "NODE_ENV=localhost COMMON_CONFIG_FILE=env/common.docker-local.env yarn cucumber",
    "cucumber:docker:debug": "NODE_ENV=localhost COMMON_CONFIG_FILE=env/common.docker-local.env PWDEBUG=1 PARALLEL=1 SCRIPT_TIMEOUT=300000 yarn cucumber",
    "cucumber:debug": "NODE_ENV=localhost COMMON_CONFIG_FILE=env/common.env PWDEBUG=1 PARALLEL=1 SCRIPT_TIMEOUT=300000 yarn cucumber",
    "cucumber:production": "NODE_ENV=production COMMON_CONFIG_FILE=env/common.env yarn cucumber",
    "cucumber:reportportal": "NODE_ENV=localhost COMMON_CONFIG_FILE=env/common.env yarn cucumber --format @reportportal/agent-js-cucumber",
    "trace:show": "npx playwright show-trace",
    "postcucumber": "COMMON_CONFIG_FILE=env/common.env ts-node ./src/reporter/cucumber-report.ts"
  },
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@babel/cli": "^7.28.0",
    "@babel/core": "^7.28.0",
    "@babel/preset-env": "^7.29.0",
    "@babel/preset-typescript": "^7.28.0",
    "@cucumber/cucumber": "^8.11.0",
    "@reportportal/agent-js-cucumber": "^5.6.0",
    "@types/node": "^22.0.0",
    "axe-html-reporter": "^2.2.11",
    "axe-playwright": "^2.2.0",
    "cucumber-html-reporter": "^5.5.1",
    "dotenv": "^16.5.0",
    "faker": "^5.5.3",
    "playwright": "^1.52.0",
    "rimraf": "^6.1.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.8.0"
  },
  "resolutions": {
    "braces": "^3.0.3",
    "picomatch": "^2.3.2"
  }
}